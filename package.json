{
  "name": "kick-vod-downloader",
  "version": "2.0.1",
  "description": "A tool to download VODs from Kick.",
  "main": "./src/index.mjs",
  "private": true,
  "scripts": {
    "dev": "nodemon --ignore app/ --exec npx electron . dev",
    "prod": "next build && electron .",
    "dist": "next build && electron-builder --publish=never",
    "lint": "next lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hammanek/kick-vod-downloader.git"
  },
  "author": "Hamman",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Hammanek/kick-vod-downloader/issues"
  },
  "homepage": "https://github.com/Hammanek/kick-vod-downloader#readme",
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "m3u8-parser": "^7.2.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-config-next": "^16.1.6",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  },
  "build": {
    "appId": "one.crawleyyou.kick-vod-downloader",
    "productName": "Kick VOD Downloader",
    "icon": "public/logo.png",
    "extraResources": [
      {
        "from": "ffmpeg.exe",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "snap": {
      "confinement": "classic"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "msi": {
      "oneClick": false,
      "perMachine": false
    }
  }
}